<Window x:Class="AcademicRecords.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:algebra="clr-namespace:AcademicRecords.Shared.Algebra;assembly=AcademicRecords.Shared"
        Title="Academic Records Algebraic Query Tree Visualizer"
        Height="920"
        MinHeight="760"
        Width="1320"
        MinWidth="1080"
        Background="#F4F6F8">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type algebra:AlgebraNode}" ItemsSource="{Binding Children}">
            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="8" Margin="4" Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#0F172A" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}" Foreground="#64748B" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0F766E" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="WrappedCell" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="210" MinHeight="130" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" MinHeight="260" />
            <RowDefinition Height="6" />
            <RowDefinition Height="260" MinHeight="180" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="SQL Editor">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>
                <TextBox x:Name="SqlEditor"
                         Grid.Row="0"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
                <DockPanel Grid.Row="1" LastChildFill="True">
                    <Button x:Name="AnalyzeButton"
                            DockPanel.Dock="Right"
                            Content="Analyze Query"
                            Click="AnalyzeButton_Click" />
                    <Button x:Name="RefreshHealthButton"
                            DockPanel.Dock="Right"
                            Content="Refresh Health"
                            Background="#334155"
                            BorderBrush="#334155"
                            Click="RefreshHealthButton_Click" />
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Foreground="#475569"
                               TextWrapping="Wrap"
                               Text="Coordinator: http://localhost:5000" />
                </DockPanel>
            </Grid>
        </GroupBox>

        <GridSplitter Grid.Row="1"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      Background="#CBD5E1" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Initial Algebraic Query Tree">
                <TreeView x:Name="InitialTreeView"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          Background="#CBD5E1" />

            <GroupBox Grid.Column="2" Header="Optimized Algebraic Query Tree">
                <TreeView x:Name="OptimizedTreeView"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </GroupBox>
        </Grid>

        <GridSplitter Grid.Row="3"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      Background="#CBD5E1" />

        <TabControl Grid.Row="4" Margin="8">
            <TabItem Header="Transformation Analysis">
                <DataGrid x:Name="TransformationsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          EnableRowVirtualization="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Step}" Width="48" />
                        <DataGridTextColumn Header="Rule" Binding="{Binding Rule}" Width="170">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="After" Binding="{Binding After}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="3*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Distributed Plan">
                <DataGrid x:Name="DistributedPlanGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          EnableRowVirtualization="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Relation" Binding="{Binding Relation}" Width="110" />
                        <DataGridTextColumn Header="Fragment" Binding="{Binding Fragment}" Width="190" />
                        <DataGridTextColumn Header="Preferred" Binding="{Binding PreferredSite}" Width="90" />
                        <DataGridTextColumn Header="Selected" Binding="{Binding SelectedSite}" Width="90" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Data Preview">
                <DataGrid x:Name="DataPreviewGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          EnableRowVirtualization="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Site" Binding="{Binding SiteId}" Width="90" />
                        <DataGridTextColumn Header="Relation" Binding="{Binding Relation}" Width="120" />
                        <DataGridTextColumn Header="Fragment" Binding="{Binding Fragment}" Width="190" />
                        <DataGridTextColumn Header="Rows" Binding="{Binding RowCount}" Width="70" />
                        <DataGridTextColumn Header="Sample Rows" Binding="{Binding SampleRows}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource WrappedCell}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Site Health">
                <DockPanel>
                    <ItemsControl x:Name="WarningsList" DockPanel.Dock="Bottom" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#B45309" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ListView x:Name="SiteHealthList">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Site" DisplayMemberBinding="{Binding Name}" Width="90" />
                                <GridViewColumn Header="Online" DisplayMemberBinding="{Binding Online}" Width="80" />
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="520" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
